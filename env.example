# UnieConnectBackend environment variables (example)
# Copy to `.env` for local dev:
#   copy env.example .env   (Windows)
#   cp env.example .env     (macOS/Linux)
#
# IMPORTANT FOR PRODUCTION:
# - WMS_API_URL MUST point to your production UnieBackend (e.g. https://api.uniewms.com)
# - If WMS_API_URL is missing or localhost in production, warehouse/OMS calls will fail with ECONNREFUSED
# - Set env vars via your hosting provider's secret manager (Vercel, Railway, etc.)

NODE_ENV=development
PORT=4001

# MongoDB (required)
DB_URL=mongodb://localhost:27017/unieconnect

# JWT signing secret (required – users/tokens)
AUTH_SECRET=change-me

# === CRITICAL FOR WAREHOUSE / OMS CONNECT FLOW ===
# UnieBackend (WMS) API base URL – NO trailing slash
# Local dev:  http://localhost:8000
# Production: https://api.uniewms.com  (or your production WMS URL)
WMS_API_URL=http://localhost:8000

# Internal API key – must match UnieBackend's UNIECONNECT_INTERNAL_API_KEY
# Required for /internal/oms/warehouses and /internal/oms/connect
UNIECONNECT_INTERNAL_API_KEY=your-internal-api-key-here

# Base URL of this API (for OAuth callbacks, webhooks)
# Production: https://api.unieconnect.com
APP_BASE_URL=http://localhost:4001

# Frontend origin (for CORS, redirects)
# Production: https://user.unieconnect.com
FRONTEND_ORIGIN=http://localhost:3000

# --- Optional ---
# CORS_ORIGINS=https://user.unieconnect.com,https://localhost:3000
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# Super admin email
# SUPER_ADMIN_EMAIL=franco@unielogics.com
